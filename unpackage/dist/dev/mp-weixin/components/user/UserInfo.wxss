.user-card.data-v-cec05d0b {
  display: flex;
  align-items: flex-start;
  /* 顶部对齐，更美观 */
  padding: 20rpx;
}
.user-card-left.data-v-cec05d0b {
  margin-right: 32rpx;
}
.avatar-circle.data-v-cec05d0b {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #355ac9;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.avatar-text.data-v-cec05d0b {
  font-size: 24rpx;
  color: #355ac9;
}
.avatar-img.data-v-cec05d0b {
  width: 100%;
  height: 100%;
}
.user-card-right.data-v-cec05d0b {
  flex: 1;
  /* 占满剩余宽度 */
}

/* 新增容器：确保名字行能撑满右侧区域 */
.user-name-container.data-v-cec05d0b {
  width: 100%;
}
.user-name-row.data-v-cec05d0b {
  display: flex;
  align-items: center;
  justify-content: space-between;
  /* 关键：名字左、铅笔右 */
  width: 100%;
  /* 占满容器宽度 */
}
.user-name.data-v-cec05d0b {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}
.edit-icon.data-v-cec05d0b {
  font-size: 28rpx;
  color: #666;
  margin-left: 0;
  /* 移除默认左边距 */
}
.user-subtitle.data-v-cec05d0b {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #888;
  display: block;
  /* 独占一行 */
}
.user-auth-status.data-v-cec05d0b {
  margin-top: 16rpx;
  display: inline-block;
}