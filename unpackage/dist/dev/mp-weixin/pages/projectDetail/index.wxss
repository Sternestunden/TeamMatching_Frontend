
/* 页面容器：给 NavBar 和底部按钮留空间 */
.detail-page.data-v-809ade6b {
  min-height: 100vh;
  background-color: #fff;
  padding-bottom: 80px; /* 给底部按钮预留空间 */
}
.detail-page--no-action.data-v-809ade6b {
  padding-bottom: 24px;
}

/* 内容区 */
.detail-content.data-v-809ade6b {
  padding: 15px 20px;
}

/* 第二行：项目名称（黑体粗字） */
.project-title.data-v-809ade6b {
  font-size: 28px;
  font-weight: bold;
  color: #000;
  margin-bottom: 15px;
}

/* 第三行：项目 Tag */
.project-tags.data-v-809ade6b {
  display: flex;
  gap: 20px;
  margin-bottom: 20px;
}
.tag-item.data-v-809ade6b {
  display: flex;
  align-items: center;
  gap: 5px;
  color: #666;
  font-size: 14px;
}
.tag-icon.data-v-809ade6b {
  font-size: 16px;
}
.tag-text.data-v-809ade6b {
  color: #666;
}

/* 第四行：队长信息 */
.leader-info.data-v-809ade6b {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 15px 0;
  border-top: 1px solid #f0f0f0;
  border-bottom: 1px solid #f0f0f0;
  margin-bottom: 20px;
}
.leader-name.data-v-809ade6b {
  font-size: 16px;
  color: #000;
  flex: 1;
}
.arrow.data-v-809ade6b {
  font-size: 18px;
  color: #999;
}
.leader-info.disabled.data-v-809ade6b {
  opacity: 0.95;
}
.anon-contact.data-v-809ade6b {
  margin: -12px 0 20px;
  padding: 12px;
  background: #f9fafb;
  border-radius: 8px;
}
.anon-contact-label.data-v-809ade6b {
  display: block;
  font-size: 12px;
  color: #888;
  margin-bottom: 6px;
}
.anon-contact-text.data-v-809ade6b {
  font-size: 14px;
  color: #333;
  line-height: 1.5;
}

/* 项目详情 */
.project-detail.data-v-809ade6b {
  margin-top: 20px;
}
.detail-title.data-v-809ade6b {
  font-size: 20px;
  font-weight: bold;
  color: #000;
  margin-bottom: 12px;
}
.detail-content-text.data-v-809ade6b {
  font-size: 14px;
  color: #333;
  line-height: 1.6;
}

/* 底部固定按钮 */
.bottom-btn.data-v-809ade6b {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 12px 20px;
  background-color: #fff;
  border-top: 1px solid #eee;
}
.communicate-btn.data-v-809ade6b {
  width: 80%;
  height: 48px;
  background-color: #003399;
  color: #fff;
  font-size: 18px;
  border-radius: 4px;
  border: none;
  left:-20px;
}
.communicate-btn.data-v-809ade6b:active {
  background-color: #002673;
}
.role-section.data-v-809ade6b {
  margin-top: 24px;
  padding-top: 16px;
  border-top: 1px solid #f0f0f0;
}
.role-block.data-v-809ade6b {
  margin-bottom: 16px;
  padding: 12px;
  background: #f9fafb;
  border-radius: 8px;
}
.role-line.data-v-809ade6b {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}
.role-name.data-v-809ade6b {
  font-size: 15px;
  font-weight: 600;
  color: #000;
}
.role-quota.data-v-809ade6b {
  font-size: 13px;
  color: #666;
}
.role-req-text.data-v-809ade6b {
  font-size: 13px;
  color: #555;
  line-height: 1.5;
}
.apply-mask.data-v-809ade6b {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
  z-index: 999;
}
.apply-panel.data-v-809ade6b {
  width: 100%;
  background: #fff;
  border-radius: 16px 16px 0 0;
  padding: 14px 14px calc(14px + env(safe-area-inset-bottom));
  box-sizing: border-box;
  max-height: 80vh;
  overflow-y: auto;
}
.apply-header.data-v-809ade6b {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}
.apply-title.data-v-809ade6b {
  font-size: 16px;
  font-weight: 600;
  color: #111;
}
.apply-close.data-v-809ade6b {
  font-size: 18px;
  color: #999;
}
.apply-item.data-v-809ade6b {
  margin-bottom: 12px;
}
.apply-label.data-v-809ade6b {
  display: block;
  font-size: 13px;
  color: #555;
  margin-bottom: 8px;
}
.role-select-grid.data-v-809ade6b {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.role-select-card.data-v-809ade6b {
  border: 1px solid #e5e7eb;
  background: #fff;
  border-radius: 10px;
  padding: 8px;
}
.role-select-card.active.data-v-809ade6b {
  border-color: #1677ff;
  background: #eef5ff;
}
.role-select-text.data-v-809ade6b {
  font-size: 12px;
  color: #222;
  line-height: 1.4;
}
.apply-textarea.data-v-809ade6b {
  width: 100%;
  min-height: 90px;
  border: 1px solid #e5e7eb;
  border-radius: 10px;
  padding: 10px 12px;
  box-sizing: border-box;
  font-size: 14px;
  color: #222;
}
.apply-row.data-v-809ade6b {
  display: flex;
  align-items: center;
  gap: 8px;
}
.apply-row-text.data-v-809ade6b {
  font-size: 13px;
  color: #333;
}
.apply-tip.data-v-809ade6b {
  display: block;
  margin-top: 6px;
  font-size: 12px;
  color: #888;
}
.upload-line.data-v-809ade6b {
  margin-top: 10px;
  display: flex;
  align-items: center;
  gap: 10px;
}
.upload-btn.data-v-809ade6b {
  width: 140px;
  height: 34px;
  line-height: 34px;
  border-radius: 8px;
  background: #eef5ff;
  color: #1677ff;
  font-size: 13px;
  border: 1px solid #d6e6ff;
  margin: 0;
}
.upload-name.data-v-809ade6b {
  flex: 1;
  font-size: 12px;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.upload-op.data-v-809ade6b {
  font-size: 12px;
  color: #1677ff;
  padding: 4px 0;
}
.upload-op.danger.data-v-809ade6b {
  color: #ff4d4f;
}
.apply-summary.data-v-809ade6b {
  margin-top: 12px;
  border: 1px solid #e8eef9;
  background: #f8fbff;
  border-radius: 10px;
  padding: 10px;
}
.summary-title.data-v-809ade6b {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #1f2a44;
  margin-bottom: 6px;
}
.summary-item.data-v-809ade6b {
  display: block;
  font-size: 12px;
  color: #4b5563;
  line-height: 1.6;
}
.apply-footer.data-v-809ade6b {
  margin-top: 14px;
  display: flex;
  gap: 10px;
}
.apply-cancel.data-v-809ade6b,
.apply-submit.data-v-809ade6b {
  flex: 1;
  height: 40px;
  line-height: 40px;
  border-radius: 10px;
  font-size: 14px;
}
.apply-cancel.data-v-809ade6b {
  background: #f3f4f6;
  color: #333;
}
.apply-submit.data-v-809ade6b {
  background: #1677ff;
  color: #fff;
}
