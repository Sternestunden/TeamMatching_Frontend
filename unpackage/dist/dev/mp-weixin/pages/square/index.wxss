
.square-page.data-v-0838208e {
  min-height: 100vh;
  background: #f5f7fb;
  padding-top: 25%;
}
.filter-header.data-v-0838208e {
  position: fixed; top: 40px; left: 0; width: 92%;
  background: #fff; padding: 15px 15px;
  border-bottom: 1px solid #eee; z-index: 99;
}
.filter-row1.data-v-0838208e {
  display: flex; justify-content: space-between; align-items: center;
}
.sort-filter.data-v-0838208e {
  display: flex; gap: 20px;
}
.sort-item.data-v-0838208e {
  font-size: 16px; color: #666;
}
.sort-item.active.data-v-0838208e {
  color: #007aff; font-weight: bold; border-bottom: 2px solid #007aff;
}
.search-bar.data-v-0838208e {
  background: #f5f5f5; border-radius: 20px; padding: 5px 15px; width: 180px;
  display: flex; align-items: center;
}
.search-input.data-v-0838208e {
  border: none; outline: none; background: transparent; flex: 1;
}
.filter-row2.data-v-0838208e {
  display: flex; gap: 20px; margin-top: 15px;
}
.category-item.data-v-0838208e {
  font-size: 14px; color: #666;
}
.category-item.active.data-v-0838208e {
  color: #007aff; font-weight: bold;
}
.filter-btn.data-v-0838208e {
  margin-left: auto; border: 1px solid #007aff; padding: 3px 8px; border-radius: 4px; color: #007aff;
}
.project-list.data-v-0838208e {
  padding: 10px;
}
.empty-tip.data-v-0838208e {
  text-align: center; padding: 50px 0; color: #999;
}

/* 筛选弹窗 */
.filter-modal.data-v-0838208e {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100vh;
  background: rgba(0,0,0,0.4);
  z-index: 999;
  animation: fadeIn-0838208e 0.3s ease;
}
.filter-panel.data-v-0838208e {
  width: 85vw;
  height: 100vh;
  background: #fff;
  display: flex;
  flex-direction: column;
  animation: slideIn-0838208e 0.3s ease;
}
@keyframes fadeIn-0838208e {
from { opacity: 0;
}
to { opacity: 1;
}
}
@keyframes slideIn-0838208e {
from { transform: translateX(-100%);
}
to { transform: translateX(0);
}
}

/* 筛选头部 */
.filter-header-top.data-v-0838208e {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  border-bottom: 1rpx solid #eee;
}
.close-icon.data-v-0838208e {
  position: absolute;
  left: 30rpx;
  font-size: 40rpx;
  color: #333;
}
.filter-title.data-v-0838208e {
  font-size: 36rpx;
  font-weight: bold;
}

/* 主体左右布局 */
.filter-body.data-v-0838208e {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* 左侧：筛选分类 */
.filter-sidebar.data-v-0838208e {
  width: 200rpx;
  background: #f5f5f5;
  flex-shrink: 0;
}
.sidebar-item.data-v-0838208e {
  display: block;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  color: #333;
  border-left: 6rpx solid transparent;
}
.sidebar-item.active.data-v-0838208e {
  background: #fff;
  border-left-color: #003399;
  color: #003399;
  font-weight: bold;
}

/* 右侧：选项内容 */
.filter-content.data-v-0838208e {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}
.filter-section.data-v-0838208e {
  margin-bottom: 40rpx;
}
.section-title.data-v-0838208e {
  font-size: 32rpx;
  font-weight: 500;
  margin-bottom: 20rpx;
  display: block;
}
.option-grid.data-v-0838208e {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}
.filter-option.data-v-0838208e {
  height: 70rpx;
  line-height: 70rpx;
  text-align: center;
  font-size: 28rpx;
  border: 2rpx solid #ddd;
  border-radius: 8rpx;
  background: #f5f5f5;
}
.filter-option.selected.data-v-0838208e {
  border-color: #003399;
  background: #e6f0ff;
  color: #003399;
}

/* 底部按钮 */
.filter-footer.data-v-0838208e {
  display: flex;
  padding: 20rpx 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #eee;
}
.btn-clear.data-v-0838208e {
  flex: 1;
  height: 80rpx;
  background: #f5f5f5;
  color: #666;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
}
.btn-confirm.data-v-0838208e {
  flex: 2;
  height: 80rpx;
  background: #003399;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: bold;
}
button.data-v-0838208e::after {
  border: none;
}
