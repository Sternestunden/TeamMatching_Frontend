
page.data-v-7fad0a1c {
  background-color: #f7f8fa;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", "Microsoft YaHei", 黑体, Arial, sans-serif;
}
.settings-page.data-v-7fad0a1c {
  background-color: #f7f8fa;
  min-height: 100vh;
  padding: 20px 20px 0;
}
.section.data-v-7fad0a1c {
  margin-bottom: 24px;
}
.section-title.data-v-7fad0a1c {
  font-size: 16px;
  color: #999;
  margin: 0 0 12px 8px;
}
.card.data-v-7fad0a1c {
  background: #ffffff;
  border-radius: 16px;
  overflow: hidden;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}
.item.data-v-7fad0a1c {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18px 20px;
  font-size: 18px;
  color: #333333;
}
.item.divider.data-v-7fad0a1c {
  border-top: 1px solid #f0f0f0;
}
.item-label.data-v-7fad0a1c {
  font-size: 18px;
  color: #222;
}
.item-arrow.data-v-7fad0a1c {
  color: #bbbbbb;
  font-size: 18px;
  font-weight: bold;
}
.item-badge.data-v-7fad0a1c {
  color: #003399;
  font-size: 18px;
  font-weight: 500;
}

/* 开关样式：背景条为蓝色，滑块为白色 */
.item-switch.data-v-7fad0a1c {
  transform: scale(0.9);
}
.data-v-7fad0a1c .uni-switch-input {
  width: 37pt !important;
  height: 20pt !important;
}
/* 开关背景条：与ECNU已认证一致的蓝色 #003399 */
.data-v-7fad0a1c .uni-switch-input::before {
  background-color: #003399 !important;
  border-radius: 10pt !important;
}
/* 开关滑块：白色 #ffffff */
.data-v-7fad0a1c .uni-switch-input::after {
  background-color: #ffffff !important;
  border-radius: 8pt !important;
  width: 16pt !important;
  height: 16pt !important;
  top: 2pt !important;
  right: 2pt !important;
}
.logout-wrapper.data-v-7fad0a1c {
  margin-top: 30px;
  padding: 0;
}
.logout-btn.data-v-7fad0a1c {
  width: 100%;
  height: 50px;
  background-color: #ffffff;
  color: #003399;
  border: 1px solid #e5e5e5;
  border-radius: 25px;
  font-size: 18px;
  font-weight: 500;
  padding: 0;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
}
.data-v-7fad0a1c .logout-btn::after {
  border: none;
}
