.user-page {
  padding: 32rpx;
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx 40rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
}
.profile-card {
  margin-top: 16rpx;
}
.profile-avatar {
  display: flex;
  justify-content: center;
  margin-bottom: 24rpx;
}
.avatar-circle {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  border: 4rpx solid #355ac9;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.avatar-text {
  font-size: 24rpx;
  color: #355ac9;
}
.avatar-img {
  width: 100%;
  height: 100%;
}
.form-item {
  margin-top: 16rpx;
}
.form-label {
  font-size: 24rpx;
  color: #555;
}
.form-input {
  margin-top: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0ea;
  font-size: 24rpx;
}
.resume-row {
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}
.resume-btn {
  width: 180rpx;
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
  border-radius: 14rpx;
  color: #355ac9;
  background: #eef3ff;
  border: 2rpx solid #d8e4ff;
  margin: 0;
}
.resume-name {
  flex: 1;
  font-size: 22rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.picker-value {
  margin-top: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0ea;
  font-size: 24rpx;
  color: #333;
  background: #fff;
}
.form-textarea {
  margin-top: 8rpx;
  padding: 16rpx 20rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e0e0ea;
  font-size: 24rpx;
  min-height: 160rpx;
}
.btn {
  margin-top: 32rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  border-radius: 20rpx;
}
.btn-primary {
  background-color: #355ac9;
  color: #fff;
}