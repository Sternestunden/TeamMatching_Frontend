<view class="user-page"><view wx:if="{{a}}" class="launched-wrapper"><view wx:if="{{b}}" class="empty-container"><text class="empty-text">暂无已发布的项目</text><text class="empty-hint">在「新建项目」中发布后即可在此查看与管理</text></view><view wx:for="{{c}}" wx:for-item="item" wx:key="j" class="project-card launched-card"><view class="launched-head" bindtap="{{item.d}}"><text class="project-title">{{item.a}}</text><text class="{{['status-pill', item.c]}}">{{item.b}}</text></view><text class="meta-line" bindtap="{{item.g}}">{{item.e}} · {{item.f}}</text><view class="launched-actions"><button class="launched-btn outline" catchtap="{{item.h}}">查看</button><button class="launched-btn primary" catchtap="{{item.i}}">编辑</button></view></view><button class="btn btn-primary create-btn" bindtap="{{d}}">创建新项目</button></view><view wx:elif="{{e}}" class="joined-wrapper"><view wx:for="{{f}}" wx:for-item="item" wx:key="c" class="{{['project-card', 'joined-card', item.d]}}" bindtap="{{item.e}}"><view class="joined-main"><text class="project-title">{{item.a}}</text><text class="status-text">{{item.b}}</text></view></view></view><view wx:else class="launched-wrapper"><view wx:if="{{g}}" class="empty-container"><text class="empty-text">草稿箱暂无内容</text></view><view wx:else><view wx:for="{{h}}" wx:for-item="item" wx:key="d" class="project-card drafted-card"><text class="project-title">{{item.a}}</text><view class="draft-btns"><button class="draft-btn del" bindtap="{{item.b}}">删除</button><button class="draft-btn edit" bindtap="{{item.c}}">继续编辑</button></view></view></view></view></view>