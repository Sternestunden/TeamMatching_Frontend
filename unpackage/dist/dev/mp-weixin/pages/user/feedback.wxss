
.feedback-page.data-v-fff60cbe {
  min-height: 100vh;
  background-color: #f5f7fb;
  padding: 20rpx;
  box-sizing: border-box;
  padding-bottom: 120rpx; /* 给底部按钮留空间 */
}
.card.data-v-fff60cbe {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* 1. 满意度模块 */
.greeting.data-v-fff60cbe {
  margin-bottom: 40rpx;
}
.greeting-text.data-v-fff60cbe {
  display: block;
  font-size: 32rpx;
  color: #333;
  margin-bottom: 20rpx;
}
.question.data-v-fff60cbe {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #222;
}
.emoji-list.data-v-fff60cbe {
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.emoji-item.data-v-fff60cbe {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.5;
  transition: all 0.2s;
}
.emoji-item.active.data-v-fff60cbe {
  opacity: 1;
  transform: scale(1.1);
}
.emoji.data-v-fff60cbe {
  font-size: 80rpx;
  margin-bottom: 10rpx;
}
.emoji-label.data-v-fff60cbe {
  font-size: 26rpx;
  color: #666;
}

/* 2. 通用标题样式 */
.section-title.data-v-fff60cbe {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #222;
  margin-bottom: 20rpx;
}

/* 3. 意见输入框 */
.feedback-textarea.data-v-fff60cbe {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  box-sizing: border-box;
  border: none;
  outline: none;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}
.feedback-textarea.data-v-fff60cbe::-webkit-input-placeholder {
  color: #999;
}
.feedback-textarea.data-v-fff60cbe::placeholder {
  color: #999;
}

/* 4. 图片上传 */
.upload-list.data-v-fff60cbe {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}
.upload-add-btn.data-v-fff60cbe {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
  display: flex;
  align-items: center;
  justify-content: center;
}
.add-icon.data-v-fff60cbe {
  font-size: 60rpx;
  color: #999;
  line-height: 1;
}
.upload-img-item.data-v-fff60cbe {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  overflow: hidden;
}
.upload-img.data-v-fff60cbe {
  width: 100%;
  height: 100%;
}
.del-img.data-v-fff60cbe {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  border-radius: 0 0 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

/* 5. 联系方式输入框 */
.contact-input.data-v-fff60cbe {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  box-sizing: border-box;
  border: none;
  outline: none;
  font-size: 28rpx;
  color: #333;
  background: transparent;
}
.contact-input.data-v-fff60cbe::-webkit-input-placeholder {
  color: #999;
}
.contact-input.data-v-fff60cbe::placeholder {
  color: #999;
}

/* 6. 底部提交按钮 */
.submit-footer.data-v-fff60cbe {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  padding: 20rpx 30rpx;
  background: #fff;
  box-sizing: border-box;
  border-top: 1rpx solid #eee;
}
.submit-btn.data-v-fff60cbe {
  width: 100%;
  height: 90rpx;
  line-height: 90rpx;
  background: #f54336;
  color: #fff;
  border: none;
  border-radius: 20rpx;
  font-size: 36rpx;
  font-weight: bold;
}
button.data-v-fff60cbe::after {
  border: none;
}
