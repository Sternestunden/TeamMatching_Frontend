.user-page {
  padding: 32rpx;
  background-color: #f5f7fb;
  min-height: 100vh;
  box-sizing: border-box;
}
.card {
  background-color: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx 28rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.04);
  margin-bottom: 24rpx;
}
.fav-title-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}
.fav-tag {
  font-size: 22rpx;
  color: #355ac9;
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background-color: #e6edff;
}
.fav-time {
  font-size: 22rpx;
  color: #999;
}
.fav-title {
  font-size: 30rpx;
  color: #333;
}
.fav-subtitle {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #888;
}
.empty-wrapper {
  margin-top: 120rpx;
  display: flex;
  justify-content: center;
}
.empty-text {
  font-size: 26rpx;
  color: #999;
}