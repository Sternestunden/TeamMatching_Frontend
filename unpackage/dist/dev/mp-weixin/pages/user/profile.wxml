<view class="user-page"><view class="card profile-card"><view class="profile-avatar" bindtap="{{c}}"><view class="avatar-circle"><image wx:if="{{a}}" class="avatar-img" src="{{b}}" mode="aspectFill"/><text wx:else class="avatar-text">上传头像</text></view></view><view class="form-item"><text class="form-label">昵称</text><input class="form-input" placeholder="请输入昵称" value="{{d}}" bindinput="{{e}}"/></view><view class="form-item"><text class="form-label">性别</text><picker range="{{g}}" range-key="label" value="{{h}}" bindchange="{{i}}"><view class="picker-value">{{f}}</view></picker></view><view class="form-item"><text class="form-label">出生日期</text><picker mode="date" value="{{k}}" bindchange="{{l}}"><view class="picker-value">{{j}}</view></picker></view><view class="form-item"><text class="form-label">年级</text><input class="form-input" placeholder="如 2022级" value="{{m}}" bindinput="{{n}}"/></view><view class="form-item"><text class="form-label">专业</text><input class="form-input" placeholder="请输入专业" value="{{o}}" bindinput="{{p}}"/></view><view class="form-item"><text class="form-label">技术栈</text><input class="form-input" placeholder="逗号分隔，如 Vue,Java" value="{{q}}" bindinput="{{r}}"/></view><view class="form-item"><text class="form-label">我的简历（投递复用）</text><view class="resume-row"><button class="resume-btn" bindtap="{{s}}">上传简历</button><text class="resume-name">{{t}}</text></view></view><view class="form-item"><text class="form-label">个人简介</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="简单介绍一下自己和擅长方向" auto-height value="{{v}}" bindinput="{{w}}"/></block></view><view class="form-item"><text class="form-label">获奖经历</text><block wx:if="{{r0}}"><textarea class="form-textarea" placeholder="如 2023年挑战杯省赛一等奖" auto-height value="{{x}}" bindinput="{{y}}"/></block></view><button class="btn btn-primary" bindtap="{{z}}">保存修改</button></view></view>