
/* 页面容器 */
.notice-detail-page.data-v-5df9fb36 {
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* 顶部导航栏（和邀请详情页一致） */
.page-header.data-v-5df9fb36 {
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 15px;
  background-color: #fff;
  border-bottom: 1px solid #eee;
}
.back-btn.data-v-5df9fb36 {
  font-size: 18px;
  color: #333;
}
.header-title.data-v-5df9fb36 {
  font-size: 16px;
  font-weight: bold;
  color: #333;
}
.empty.data-v-5df9fb36 {
  width: 18px;
}

/* 详情内容区 */
.detail-content.data-v-5df9fb36 {
  padding: 15px;
}

/* 通知头部 */
.notice-header.data-v-5df9fb36 {
  display: flex;
  align-items: center;
  padding: 15px;
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
  margin-bottom: 15px;
}
.system-icon.data-v-5df9fb36 {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: #e8f4f8;
  color: #007aff;
  font-size: 20px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.header-content.data-v-5df9fb36 {
  margin-left: 15px;
}
.notice-title.data-v-5df9fb36 {
  font-size: 18px;
  color: #333;
  font-weight: bold;
  display: block;
  margin-bottom: 5px;
}
.notice-time.data-v-5df9fb36 {
  font-size: 14px;
  color: #999;
}

/* 通知内容 */
.notice-content.data-v-5df9fb36 {
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
  padding: 20px 15px;
  margin-bottom: 20px;
}
.content-text.data-v-5df9fb36 {
  font-size: 16px;
  color: #333;
  line-height: 1.8;
}

/* 操作按钮 */
.operate-btn.data-v-5df9fb36 {
  padding: 0 15px;
}
.view-project-btn.data-v-5df9fb36 {
  width: 100%;
  height: 48px;
  background-color: #003399;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-size: 16px;
}
.view-project-btn.data-v-5df9fb36:active {
  background-color: #002673;
}
