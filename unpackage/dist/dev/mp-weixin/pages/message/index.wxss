
/* 页面容器 */
.message-page.data-v-780fc0ad {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding: 15px;
}

/* 顶部功能按钮区 */
.function-buttons.data-v-780fc0ad {
  display: flex;
  gap: 15px;
  margin-bottom: 20px;
}
.function-item.data-v-780fc0ad {
  flex: 1;
  background-color: #fff;
  padding: 20px 15px;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
  text-align: center;
}
.function-icon.data-v-780fc0ad {
  width: 48px;
  height: 48px;
  line-height: 48px;
  border-radius: 50%;
  background-color: #003399;
  color: #fff;
  font-size: 24px;
  margin: 0 auto 10px;
}
.function-title.data-v-780fc0ad {
  font-size: 16px;
  color: #000;
  display: block;
  margin-bottom: 5px;
}
.function-badge.data-v-780fc0ad {
  font-size: 14px;
  color: #ff6600;
}
.function-desc.data-v-780fc0ad {
  font-size: 14px;
  color: #666;
}

/* 消息列表 */
.message-list.data-v-780fc0ad {
  background-color: #fff;
  border-radius: 8px;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
  overflow: hidden;
}
.message-item.data-v-780fc0ad {
  display: flex;
  align-items: center;
  padding: 15px;
  border-bottom: 1px solid #f0f0f0;
  position: relative;
}
.message-item.data-v-780fc0ad:last-child {
  border-bottom: none;
}

/* 消息内容区 */
.message-content.data-v-780fc0ad {
  flex: 1;
  margin-left: 12px;
}
.message-header.data-v-780fc0ad {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 5px;
}
.name-row.data-v-780fc0ad {
  display: flex;
  align-items: center;
  gap: 8px;
}
.user-name.data-v-780fc0ad {
  font-size: 16px;
  color: #000;
}
.user-tag.data-v-780fc0ad {
  font-size: 12px;
  color: #003399;
  border: 1px solid #003399;
  padding: 1px 6px;
  border-radius: 4px;
}
.message-time.data-v-780fc0ad {
  font-size: 12px;
  color: #999;
}
.message-desc.data-v-780fc0ad {
  font-size: 14px;
  color: #666;
  line-height: 1.4;
}

/* 新消息红点 */
.message-badge.data-v-780fc0ad {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background-color: #ff3333;
  color: #fff;
  font-size: 12px;
  text-align: center;
  line-height: 20px;
  position: absolute;
  right: 15px;
  top: 50%;
  transform: translateY(-50%);
}
.badge-text.data-v-780fc0ad {
  color: #fff;
}
